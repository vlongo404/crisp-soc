[Unit]
Description=CRISP AI Pipeline (FastAPI)
After=network.target docker.service

[Service]
User=ubuntu
WorkingDirectory=/opt/crisp-soc/soc-ai
EnvironmentFile=/opt/crisp-soc/soc-ai/.env
ExecStart=/opt/crisp-soc/soc-ai/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=15

[Install]
WantedBy=multi-user.target
